{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage Limiter",
  "version": "0.1.0",
  "identifier": "com.codexusagelimiter.desktop",
  "mainBinaryName": "codex-usage-limiter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Codex Usage Limiter",
        "width": 420,
        "height": 240,
        "minWidth": 380,
        "minHeight": 220,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 12,
          "y": 10
        },
        "transparent": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "iOS": {
      "frameworks": [
        "libz.tbd",
        "libiconv.tbd"
      ]
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
